{
  "name": "Media",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "photo",
        "video",
        "screenshot"
      ],
      "default": "photo"
    },
    "url": {
      "type": "string"
    },
    "thumbnail_url": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Team Photo",
        "Tournament",
        "Match Highlight",
        "Behind the Scenes"
      ],
      "default": "Team Photo"
    },
    "date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "url",
    "type"
  ]
}